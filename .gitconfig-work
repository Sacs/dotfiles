[init]
  defaultBranch = stage

[alias]
  delete-merged-branches = "!f() { \
    DEFAULT=$(git default); \
    PROTECTED_BRANCHES=$(git config branch.protected 2>/dev/null || echo 'master main dev'); \
    git checkout --quiet ${1-$DEFAULT} && \
    git branch --merged | grep --invert-match '\\*' | grep --invert-match "$(echo $PROTECTED_BRANCHES | sed 's/ /\\|/g')" | xargs -n 1 git branch --delete; \
    git checkout --quiet @{-1}; \
}; f"
	list-remote-merged-branches = "!f() { DEFAULT=$(git default); git checkout ${1-$DEFAULT} && git fetch && git branch -r --merged ${1-$DEFAULT} | grep -v ${1-$DEFAULT} | xargs -r -n 1 echo; }; f"
	delete-remote-merged-branches = "!f() { DEFAULT=$(git default); git checkout ${1-$DEFAULT} && git fetch && git branch -r --merged ${1-$DEFAULT} | grep -v ${1-$DEFAULT} | xargs -r -t -n 1 git branch -d; }; f"
  fpull = "!f() { DEFAULT=$(git default); git fetch origin ${1-$DEFAULT} && git reset --hard FETCH_HEAD && git clean -df; }; f"


